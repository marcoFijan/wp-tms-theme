{
  "name": "wp-theme-template",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "watch:css-main": "postcss src/css/main.css -o theme/assets/css/main.css --watch",
    "watch:css-editor": "postcss src/css/editor.css -o theme/assets/css/editor.css --watch",
    "watch:js": "esbuild src/js/main.js --bundle --outfile=theme/assets/js/main.js --watch",
    "watch": "npm-run-all --parallel watch:*",
    "build:css": "NODE_ENV=production postcss src/css/main.css -o theme/assets/css/main.css && NODE_ENV=production postcss src/css/editor.css -o theme/assets/css/editor.css",
    "build:js": "esbuild src/js/main.js --bundle --minify --outfile=theme/assets/js/main.js",
    "build": "npm run build:css && npm run build:js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.9",
    "esbuild": "^0.28.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "postcss-import-ext-glob": "^2.1.1",
    "swiper": "^12.1.3",
    "tailwindcss": "^4.2.4"
  }
}
